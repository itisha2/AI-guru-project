# ── Groq (LLM) ───────────────────────────────────────────────────────────────
# Free API key from https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ── HuggingFace (embeddings only) ────────────────────────────────────────────
# Token from https://huggingface.co/settings/tokens  (needed to download models)
HUGGINGFACEHUB_API_TOKEN=hf_your_token_here

# ── Models ───────────────────────────────────────────────────────────────────
# LLM — runs on Groq (free). Options:
#   gemma2-9b-it              (default — Gemma 2 9B, strong reasoning, multilingual)
#   llama-3.1-8b-instant      (faster, good multilingual)
#   llama-3.3-70b-versatile   (best quality, still free on Groq)
#   mixtral-8x7b-32768        (long context)
LLM_MODEL=gemma2-9b-it

# Embedding model — runs locally on CPU, no API call needed
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
